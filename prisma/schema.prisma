generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid()) @map("_id")
  name     String
  username String @unique
  password String

  group         Group?       @relation("GroupMembers", fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  groupId       String?      @map("group_id")
  createdGroups Group[]      @relation("GroupCreator")
  Invitation    Invitation[]

  @@map("users")
}

model Group {
  id          String        @id @default(cuid()) @map("_id")
  name        String
  description String?
  tag         String?
  balance     Float         @default(0)
  creator     User          @relation("GroupCreator", fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creatorId   String        @map("creator_id")
  users       User[]        @relation("GroupMembers")
  Transaction Transaction[]
  Category    Category[]
  Invitation  Invitation[]
  allowFindMe Boolean       @default(true) @map("allow_find_me")
  Goal        Goal[]

  @@map("groups")
}

model Invitation {
  id      String           @id @default(cuid()) @map("_id")
  group   Group            @relation(fields: [groupId], references: [id])
  groupId String           @map("group_id")
  user    User             @relation(fields: [userId], references: [id])
  userId  String           @map("user_id")
  status  StatusInvitation @default(PENDING)

  @@map("invitations")
}

model Transaction {
  id          String            @id @default(cuid()) @map("_id")
  description String
  amount      Float
  month       Int
  year        Int
  status      StatusTransaction @default(PENDING)
  type        TypeTransaction
  category    Category          @relation(fields: [categoryId], references: [id])
  categoryId  String            @map("category_id")
  group       Group             @relation(fields: [groupId], references: [id])
  groupId     String            @map("group_id")
  uuid        String

  @@map("transactions")
}

model Goal {
  id          String     @id @default(cuid()) @map("_id")
  description String
  amount      Float
  status      StatusGoal @default(PENDING)
  dueDate     DateTime
  group       Group      @relation(fields: [groupId], references: [id])
  groupId     String     @map("group_id")

  @@map("goals")
}

model Category {
  id          String          @id @default(cuid()) @map("_id")
  description String
  type        TypeTransaction
  Transaction Transaction[]
  group       Group           @relation(fields: [groupId], references: [id])
  groupId     String          @map("group_id")

  @@map("categories")
}

model Feedback {
  id        String   @id @default(cuid()) @map("_id")
  author    String?
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedbacks")
}

enum TypeTransaction {
  EXPENSE @map("despesa")
  INCOME  @map("receita")
}

enum StatusTransaction {
  OVERDUE @map("atrasado")
  PENDING @map("pendente")
  OK      @map("ok")
}

enum StatusInvitation {
  PENDING  @map("pendente")
  ACCEPTED @map("aceito")
  REJECTED @map("rejeitado")
}

enum StatusGoal {
  PENDING @map("pendente")
  OK      @map("ok")
}
